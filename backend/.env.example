# OpenAI
OPENAI_API_KEY=sk-proj-xxx

# Dùng GPT-4o-mini 
# LLM_MODEL=gpt-4o-mini

# Chuyển sang GPT-4.1-mini
LLM_MODEL=gpt-4.1-mini

# LLM_MODEL=gpt-5.4-mini-2026-03-17

# LlamaCloud (LlamaParse)
LLAMA_CLOUD_API_KEY=llx-xxx

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx
SUPABASE_CONNECTION_STRING=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# App
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=8001

# Admin auth: required to call /api/ingest. Generate a strong random value, e.g.
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Leave empty to disable /api/ingest entirely (returns 503).
ADMIN_API_KEY=

# Rate limit for /api/chat per client IP (slowapi format).
# Examples: "30/minute", "200/hour", "10/second"
CHAT_RATE_LIMIT=30/minute
